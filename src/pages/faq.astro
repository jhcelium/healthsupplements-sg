---
import BaseLayout from "../layouts/BaseLayout.astro";
import Faq from "../components/react/Faq.tsx";
import {
  faqBreadcrumbJsonLd,
  faqFaqPageJsonLd,
  faqMetaDescription,
  faqPageTitle,
  faqWebPageJsonLd,
} from "../lib/faq-content";
---
<BaseLayout title={faqPageTitle} description={faqMetaDescription} path="/faq">
  <script slot="head" type="application/ld+json" set:html={faqWebPageJsonLd} />
  <script slot="head" type="application/ld+json" set:html={faqFaqPageJsonLd} />
  <script slot="head" type="application/ld+json" set:html={faqBreadcrumbJsonLd} />
  <Faq />
</BaseLayout>
