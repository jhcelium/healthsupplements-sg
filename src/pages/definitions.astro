---
import BaseLayout from "../layouts/BaseLayout.astro";
import Definitions from "../components/react/Definitions.tsx";
import {
  definitionsBreadcrumbJsonLd,
  definitionsDefinedTermSetJsonLd,
  definitionsMetaDescription,
  definitionsPageTitle,
  definitionsPath,
  definitionsWebPageJsonLd,
} from "../lib/definitions-content";
---
<BaseLayout title={definitionsPageTitle} description={definitionsMetaDescription} path={definitionsPath}>
  <script slot="head" type="application/ld+json" set:html={definitionsWebPageJsonLd} />
  <script slot="head" type="application/ld+json" set:html={definitionsDefinedTermSetJsonLd} />
  <script slot="head" type="application/ld+json" set:html={definitionsBreadcrumbJsonLd} />
  <Definitions />
</BaseLayout>
