---
import Seo from "../components/Seo.astro";
import site from "../../data/site.json";
interface Props {
  title?: string;
  description?: string;
  path?: string;
  ogType?: string;
  ogImage?: string;
  ogImageWidth?: string;
  ogImageHeight?: string;
  ogImageAlt?: string;
}
const {
  title,
  description,
  path,
  ogType,
  ogImage,
  ogImageWidth,
  ogImageHeight,
  ogImageAlt,
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en-SG">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <Seo
      title={title}
      description={description}
      path={path}
      ogType={ogType}
      ogImage={ogImage}
      ogImageWidth={ogImageWidth}
      ogImageHeight={ogImageHeight}
      ogImageAlt={ogImageAlt}
    />
    <slot name="head" />
    <style>
      /* ── Base ── */
      :root {
        font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        font-size: 16px;
      }
      body {
        margin: 0;
        background: #fff;
        color: #1a1a1a;
        line-height: 1.75;
      }

      /* ── Layout ── */
      main {
        max-width: 860px;
        margin: 0 auto;
        padding: 36px 20px 72px;
      }
      header {
        border-bottom: 1px solid #ddd;
        padding: 12px 20px;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      footer {
        border-top: 1px solid #ddd;
        padding: 20px;
        font-size: 13px;
        color: #666;
        margin-top: 0;
      }

      /* ── Navigation ── */
      nav a {
        margin-right: 16px;
        font-size: 14px;
        color: #444;
        text-decoration: none;
        letter-spacing: 0.01em;
      }
      nav a:hover {
        color: #0b63ce;
      }

      /* ── Logo ── */
      .header-logo {
        display: flex;
        align-items: center;
        flex-shrink: 0;
      }
      .header-logo img {
        height: 38px;
        width: auto;
        display: block;
        opacity: 0.85;
        transition: opacity 0.15s;
      }
      .header-logo:hover img {
        opacity: 1;
      }

      /* ── Typography ── */
      h1 {
        font-size: 28px;
        font-weight: 700;
        line-height: 1.2;
        letter-spacing: -0.02em;
        margin: 0 0 12px;
        color: #0d0d0d;
      }
      h2 {
        font-size: 20px;
        font-weight: 600;
        line-height: 1.3;
        margin: 44px 0 12px;
        color: #111;
      }
      h3 {
        font-size: 16px;
        font-weight: 600;
        line-height: 1.4;
        margin: 28px 0 8px;
        color: #111;
      }
      p {
        margin: 0 0 1em;
      }
      ul, ol {
        padding-left: 1.5em;
        margin: 0 0 1em;
      }
      li {
        margin-bottom: 0.35em;
        line-height: 1.7;
      }
      a {
        color: #0b63ce;
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
      }

      /* ── Lead / Subtitle ── */
      .subtitle {
        font-size: 17px;
        color: #444;
        line-height: 1.65;
        margin: 0 0 24px;
      }

      /* ── Disclaimer ── */
      .disclaimer {
        border: 1px solid #d8d8d8;
        border-left: 3px solid #aaa;
        background: #f9f9f9;
        padding: 12px 16px;
        font-size: 13px;
        line-height: 1.6;
        color: #555;
        margin: 0 0 32px;
      }

      /* ── Primary CTA ── */
      .cta-link {
        display: inline-block;
        border: 1px solid #0b63ce;
        color: #0b63ce;
        padding: 9px 18px;
        font-size: 14px;
        text-decoration: none;
        margin-bottom: 32px;
        letter-spacing: 0.01em;
      }
      .cta-link:hover {
        background: #f0f5ff;
        text-decoration: none;
      }

      /* ── Infographic ── */
      .infographic {
        margin: 40px 0;
        padding: 0;
      }
      .infographic img {
        width: 100%;
        height: auto;
        display: block;
        border: 1px solid #ddd;
      }
      .infographic figcaption {
        font-size: 12px;
        color: #888;
        margin-top: 8px;
        text-align: center;
        font-style: italic;
      }

      /* ── Cross Reference (hub link) ── */
      .hub-notice {
        font-size: 14px;
        color: #333;
        border: 1px solid #d0d0d0;
        border-left: 3px solid #0b63ce;
        padding: 11px 16px;
        margin: 40px 0;
        background: #fafcff;
        line-height: 1.6;
      }
      .hub-notice a {
        color: #0b63ce;
      }
      .hub-notice a:hover {
        text-decoration: underline;
      }

      /* ── Brand Link (secondary outbound) ── */
      .brand-link {
        display: inline-block;
        border: 1px solid #bbb;
        color: #333;
        padding: 9px 18px;
        font-size: 14px;
        text-decoration: none;
        letter-spacing: 0.01em;
      }
      .brand-link:hover {
        border-color: #666;
        color: #111;
        background: #f5f5f5;
        text-decoration: none;
      }

      /* ── Section heading divider ── */
      .page-section {
        margin-top: 44px;
      }
      .page-section h2 {
        margin-top: 0;
        padding-bottom: 8px;
        border-bottom: 1px solid #e8e8e8;
      }

      /* ── Breadcrumb (editorial, minimal) ── */
      .breadcrumb-trail {
        font-size: 13px;
        color: #666;
        margin: 0 0 20px;
        line-height: 1.5;
      }
      .breadcrumb-trail ol {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0 6px;
      }
      .breadcrumb-trail li {
        display: flex;
        align-items: center;
        margin: 0;
      }
      .breadcrumb-trail li:not(:last-child)::after {
        content: "/";
        color: #bbb;
        margin-left: 6px;
        font-weight: 400;
        pointer-events: none;
      }
      .breadcrumb-trail a {
        color: #555;
        text-decoration: none;
      }
      .breadcrumb-trail a:hover {
        color: #0b63ce;
        text-decoration: underline;
      }
      .breadcrumb-trail [aria-current="page"] {
        color: #1a1a1a;
        font-weight: 500;
      }
    </style>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "MedicalWebPage",
      "name": "Health Supplements Singapore",
      "about": "Dietary supplements in Singapore",
      "audience": {
        "@type": "MedicalAudience",
        "audienceType": "Consumer"
      },
      "inLanguage": "en-SG"
    }
    </script>
  </head>
  <body>
    <header>
      <nav>
        <a href="/">Home</a>
        <a href="/about">About</a>
        <a href="/faq">FAQ</a>
        <a href="/label-checklist">Label Checklist</a>
            <a href="/ingredient-context">Ingredient Context</a>
            <a href="/serving-size-context">Serving Size</a>
      </nav>
      <a
        href="https://supplement.neoi.jp/en"
        target="_blank"
        rel="noopener"
        class="header-logo"
        aria-label="Visit Official Neoi Supplement Site"
      >
        <img src="/images/neoi-logo.png" alt="Neoi supplement.neoi.jp" width="120" height="38" />
      </a>
    </header>
    <main><slot /></main>
    <footer>
      <div>{site.siteName}</div>
      <div>Educational content only. Not medical or treatment advice.</div>
    </footer>
  </body>
</html>
